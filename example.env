UID=1000
GID=1000

# ComfyUI service
COMFY_PORT=8188
UPDATE_DEPS=true

# Custom nodes loading behavior
DISABLE_ALL_CUSTOM_NODES=false
# COMFY_NODE_WHITELIST=ComfyUI-Manager,ComfyUI-SAM3
# COMFY_NODE_BLACKLIST=ComfyUI-SAM3

# Attention/runtime policy
COMFY_FORCE_FLASH_ATTENTION=true
COMFY_FLASH_ATTN3_SHIM=true
INSTALL_SAGEATTENTION=false

# SAM3 behavior
# 0 = do not mutate global ComfyUI attention flags in SAM3 prestartup (recommended)
# 1 = allow legacy comfy-env global auto-enable behavior
SAM3_ALLOW_GLOBAL_ATTENTION_AUTOTUNE=0
